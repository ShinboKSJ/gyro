<Window x:Class="Gyro_Analyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Gyro_Analyzer.UserControls"
        mc:Ignorable="d"
        Title="평균 1초 / 표준편차 1분" Height="602" Width="932" FontSize="16">
    <Grid Margin="0,-1,0,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="178*" />
            <ColumnDefinition Width="177*" />
            <ColumnDefinition Width="178*" />
            <ColumnDefinition Width="177*" />
            <ColumnDefinition Width="36*" />
            <ColumnDefinition Width="89*" />
            <ColumnDefinition Width="89*" />
            <ColumnDefinition Width="16*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <local:UserGraphControl x:Name="graph_All" Grid.Row="3" Grid.RowSpan="8" Grid.Column="0" Grid.ColumnSpan="4" Visibility="Visible" DrawMode="0"/>

        <Button Grid.Row="0" Grid.Column="0" Margin="5" Content="폴더선택" Click="Button_Click_2"/>
        <Button Grid.Row="0" Grid.Column="1" Margin="5" Content="Test" Click="Button_Click"/>
        <Button Grid.Row="0" Grid.Column="2" Margin="5" Content="Stop" Click="Button_Click_1"/>

        <TextBox Grid.Row="0" Grid.Column="3" Margin="5" Text="" IsReadOnly="True" x:Name="textBox_ElapsedTime" Visibility="Hidden"/>

        <TextBlock Grid.Row="3" Grid.Column="5" Text="평균" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Grid.Row="3" Grid.Column="6" Text="표준편차" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>

        <TextBlock Grid.Row="4" Grid.Column="4" Text="X" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Grid.Row="5" Grid.Column="4" Text="Y" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBlock Grid.Row="8" Grid.Column="3" Text="R_X" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Margin="173,3,1,20" Grid.ColumnSpan="2"/>
        <TextBlock Grid.Row="9" Grid.Column="3" Text="R_Y" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Margin="173,4,1,18" Grid.ColumnSpan="2"/>

        <TextBox Grid.Row="4" Grid.Column="5" Text="0.00" Margin="2,8,0,8" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_Average_X" Grid.ColumnSpan="2" TextChanged="textBox_Average_X_TextChanged"/>
        <TextBox Grid.Row="6" Grid.Column="5" Text="0.00" Margin="3,2,15,16" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_StandardDeviation_X" Grid.ColumnSpan="3"/>

        <TextBox Grid.Row="5" Grid.Column="5" Text="0.00" Margin="2,8,0,8" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_Average_Y" Grid.ColumnSpan="2"/>
        <TextBox Grid.Row="7" Grid.Column="5" Text="0.00" Margin="2,2,15,16" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_StandardDeviation_Y" Grid.ColumnSpan="3"/>

        <TextBox Grid.Row="8" Grid.Column="5" Text="0.00" Margin="2,1,1,17" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_Average_R_X" Grid.ColumnSpan="2"/>
        <TextBox Grid.Row="10" Grid.Column="4" Text="0.00" Margin="24,42,0,66" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_StandardDeviation_R_X" Height="24" Grid.ColumnSpan="3"/>

        <TextBox Grid.Row="9" Grid.Column="5" Text="0.00" Margin="2,1,1,17" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_Average_R_Y" Grid.ColumnSpan="2"/>
        <TextBox Grid.Row="10" Grid.Column="4" Text="0.00" Margin="25,82,0,26" TextAlignment="Center" VerticalAlignment="Center" x:Name="textBox_StandardDeviation_R_Y" Height="24" Grid.ColumnSpan="3" HorizontalAlignment="Left" Width="184"/>

        <TextBlock Grid.Row="0" Grid.Column="3" Text="진행시간" VerticalAlignment="Center" TextAlignment="Right"/>
        <Viewbox Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="2">
            <local:UserControlStopWatch x:Name="stopWatch" Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" TimeTextFontSize="50" ControlButtonVisible="False" Grid.RowSpan="1"/>
        </Viewbox>

        <GroupBox Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>


                <RadioButton Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" GroupName="Mode" Margin="5" IsChecked="True" Checked="RadioButton_Checked" Tag="0" Content="최대입력각속도"/>
                <RadioButton Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" GroupName="Mode" Margin="5" Checked="RadioButton_Checked" Tag="1" Content="선형오차, 환산계수"/>
                <RadioButton Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" GroupName="Mode" Margin="5" Checked="RadioButton_Checked" Tag="2" Content="편류안정"/>
                <RadioButton Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" GroupName="Mode" Margin="5" Checked="RadioButton_Checked" Tag="3" Content="최소감지각속도"/>
                <RadioButton Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" GroupName="Mode" Margin="5" Checked="RadioButton_Checked" Tag="4" Content="시동시간"/>
                <RadioButton Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" GroupName="Mode" Margin="5" Checked="RadioButton_Checked" Tag="5" Content="대역폭"/>
            </Grid>
        </GroupBox>
        <TextBlock Grid.Row="10" Grid.Column="5" Text="편류 안정" TextAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Margin="28,16,36,95" Grid.ColumnSpan="2"/>

        <Rectangle Grid.Row="0" Grid.Column="7" MouseRightButtonDown="Rectangle_MouseRightButtonDown" Fill="Transparent"/>

        <Grid x:Name="grid_Mode" Grid.Row="0" Grid.Column="6" Grid.RowSpan="2" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.ColumnSpan="3" Text="수정치" VerticalAlignment="Center" HorizontalAlignment="Center"/>

            <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="1"/>
            <TextBlock Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="1/3"/>
            <TextBlock Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="1/10"/>

            <RadioButton Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Right" GroupName="Avgerage" IsChecked="True" Checked="RadioButton_Checked_1" Tag="0" Content=""/>
            <RadioButton Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Right" GroupName="Avgerage" Checked="RadioButton_Checked_1" Tag="1" Content=""/>
            <RadioButton Grid.Column="2" Grid.Row="2" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Right" GroupName="Avgerage" Checked="RadioButton_Checked_1" Tag="2" Content=""/>
            
        </Grid>
    </Grid>
</Window>
