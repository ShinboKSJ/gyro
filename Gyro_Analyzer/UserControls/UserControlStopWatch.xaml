<UserControl x:Class="Gyro_Analyzer.UserControls.UserControlStopWatch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gyro_Analyzer.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300" FontSize="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"></RowDefinition>
            <RowDefinition Height="1*"></RowDefinition>
        </Grid.RowDefinitions>
        <TextBlock x:Name="textBlock_CurrentTime" Margin="10" Text="000:0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="80"/>
        <Grid x:Name="grid_Control_Button" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
                <ColumnDefinition Width="1*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="button_Start" Grid.Column="0" Margin="10" Content="시작" Click="button_Start_Click"/>
            <Button x:Name="button_Stop" Grid.Column="1" Margin="10" Content="정지" Click="button_Stop_Click"/>
            <Button x:Name="button_Reset" Grid.Column="2" Margin="10" Content="초기화" Click="button_Reset_Click"/>
        </Grid>
    </Grid>
</UserControl>
