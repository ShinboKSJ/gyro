<UserControl x:Class="Gyro_Analyzer.UserControls.UserGraphControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="500" FontSize="20">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="0.2*"/>
        </Grid.RowDefinitions>

        <WindowsFormsHost x:Name="windowsFormHost" Grid.Row="0" Grid.RowSpan="8" Grid.ColumnSpan="2" Foreground="Black" Background="Transparent"/>

        <!--<TextBlock Grid.Column="1" Grid.Row="3" Text="출력시간" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="textBox_OutputTime" Grid.Column="1" Grid.Row="4" Text="00.0 ms" HorizontalAlignment="Center" VerticalAlignment="Center" IsReadOnly="True"/>
        <TextBlock Grid.Column="1" Grid.Row="1" Text="출력전류" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <TextBox x:Name="textBox_OutputCurrent" Grid.Column="1" Grid.Row="2" Text="00.0 A" HorizontalAlignment="Center" VerticalAlignment="Center" IsReadOnly="True"/>-->

    </Grid>
</UserControl>
